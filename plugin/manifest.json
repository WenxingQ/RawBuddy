{
  "id": "com.rawbuddy.plugin",
  "name": "RawBuddy",
  "version": "1.0.0",
  "manifestVersion": 5,
  "host": [
    { "app": "PS", "minVersion": "27.0" }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "rawbuddy-panel",
      "label": { "default": "RawBuddy" },
      "main": "index.html",
      "minimumSize": { "width": 300, "height": 400 },
      "preferredDockedSize": { "width": 320, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["https://api.anthropic.com"]
    },
    "localFileSystem": "plugin"
  }
}
