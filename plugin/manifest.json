{
  "id": "com.rawbuddy.plugin",
  "name": "RawBuddy",
  "version": "1.0.0",
  "manifestVersion": 5,
  "host": [
    { "app": "PS", "minVersion": "27.0" }
  ],
  "_note_vision": "ps.imaging (getPixels/encodeImageData) requires PS 27.2+. On 27.0–27.1 captureDocumentImage() returns null and the plugin operates text-only.",
  "entrypoints": [
    {
      "type": "panel",
      "id": "rawbuddy-panel",
      "label": { "default": "RawBuddy" },
      "main": "index.html",
      "minimumSize": { "width": 340, "height": 500 },
      "preferredDockedSize": { "width": 360, "height": 640 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["https://api.anthropic.com"]
    },
    "localFileSystem": "plugin"
  }
}
